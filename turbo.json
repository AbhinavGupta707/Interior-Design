{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "format:check": {
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:contract": { "outputs": [] },
    "test:integration": { "outputs": [] },
    "test:geometry": { "outputs": [] },
    "test:security": { "outputs": [] },
    "test:e2e": { "cache": false, "outputs": ["playwright-report/**", "test-results/**"] },
    "api:check": { "outputs": [] },
    "dependency:boundaries": { "outputs": [] }
  }
}
