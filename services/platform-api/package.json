{
  "name": "@interior-design/platform-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./design-options": {
      "types": "./src/modules/design-options/index.ts",
      "development": "./src/modules/design-options/index.ts",
      "default": "./dist/src/modules/design-options/index.js"
    },
    "./reconstruction": {
      "types": "./src/modules/reconstruction/index.ts",
      "development": "./src/modules/reconstruction/index.ts",
      "default": "./dist/src/modules/reconstruction/index.js"
    },
    "./scenes": {
      "types": "./src/modules/scenes/index.ts",
      "development": "./src/modules/scenes/index.ts",
      "default": "./dist/src/modules/scenes/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --conditions=development src/server.ts",
    "lint": "eslint src test",
    "start": "node dist/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "vitest run --exclude 'dist/**'",
    "test:contract": "vitest run --passWithNoTests --exclude 'dist/**'",
    "test:integration": "vitest run --passWithNoTests --exclude 'dist/**'"
  },
  "devDependencies": {
    "@interior-design/scene-compiler": "workspace:*",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "@aws-sdk/s3-request-presigner": "^3.1089.0",
    "@interior-design/authz": "workspace:*",
    "@interior-design/catalog": "workspace:*",
    "@interior-design/config": "workspace:*",
    "@interior-design/contracts": "workspace:*",
    "@interior-design/design-engine": "workspace:*",
    "@interior-design/design-brief": "workspace:*",
    "@interior-design/domain-model": "workspace:*",
    "@interior-design/geometry-kernel": "workspace:*",
    "@interior-design/interior-assets": "workspace:*",
    "@interior-design/model-gateway": "workspace:*",
    "@interior-design/model-operations": "workspace:*",
    "@interior-design/provider-adapters": "workspace:*",
    "@interior-design/provenance": "workspace:*",
    "@interior-design/specification": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "fastify": "^5.10.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  }
}
