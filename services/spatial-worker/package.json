{
  "name": "@interior-design/spatial-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --conditions=development src/index.ts",
    "lint": "eslint src test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "vitest run --passWithNoTests --exclude 'dist/**'",
    "test:contract": "vitest run --passWithNoTests --exclude 'dist/**'",
    "test:integration": "vitest run --passWithNoTests --exclude 'dist/**'"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "@interior-design/contracts": "workspace:*",
    "@interior-design/geometry-kernel": "workspace:*",
    "@interior-design/platform-api": "workspace:*",
    "@interior-design/provider-adapters": "workspace:*",
    "@interior-design/scene-compiler": "workspace:*",
    "file-type": "^22.0.1",
    "postgres": "^3.4.9",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  }
}
