{
  "name": "@interior-design/geometry-kernel",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src test --no-error-on-unmatched-pattern",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "vitest run --passWithNoTests --exclude 'dist/**'",
    "test:geometry": "vitest run --exclude 'dist/**'"
  },
  "dependencies": {
    "@interior-design/contracts": "workspace:*"
  }
}
