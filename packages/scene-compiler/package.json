{
  "name": "@interior-design/scene-compiler",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src test --no-error-on-unmatched-pattern",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "vitest run --passWithNoTests --exclude 'dist/**'"
  },
  "dependencies": {
    "@interior-design/catalog": "workspace:*",
    "@interior-design/contracts": "workspace:*",
    "@interior-design/geometry-kernel": "workspace:*",
    "@interior-design/specification": "workspace:*",
    "earcut": "^3.2.3",
    "gltf-validator": "2.0.0-dev.3.10"
  }
}
