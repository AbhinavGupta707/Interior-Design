{
  "name": "@interior-design/authz",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src test ../../tests/security/identity",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p ../../tests/security/identity/tsconfig.json --noEmit",
    "test:unit": "vitest run test --exclude 'dist/**'",
    "test:security": "vitest --root ../.. run tests/security/identity"
  },
  "dependencies": {
    "@interior-design/contracts": "workspace:*"
  }
}
